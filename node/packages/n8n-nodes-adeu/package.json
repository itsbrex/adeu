{
  "name": "n8n-nodes-adeu",
  "version": "1.21.0",
  "description": "n8n community node for Adeu — apply AI-driven tracked changes, generate diffs, and sanitize Microsoft Word (.docx) documents.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "adeu",
    "docx",
    "word",
    "redline",
    "track-changes",
    "diff",
    "openxml"
  ],
  "license": "MIT",
  "homepage": "https://adeu.ai",
  "author": {
    "name": "Mikko Korpela",
    "email": "mikko@adeu.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dealfluence/adeu.git",
    "directory": "node/packages/n8n-nodes-adeu"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/nodes/Adeu/Adeu.node.js",
  "scripts": {
    "build": "tsup && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 \"nodes/**/*.svg\" \"nodes/**/*.json\" dist/nodes/",
    "dev": "tsup --watch",
    "lint": "eslint nodes/**/*.ts",
    "lintfix": "eslint nodes/**/*.ts --fix",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/Adeu/Adeu.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@adeu/core": "^1.21.0",
    "@n8n/eslint-plugin-community-nodes": "^0.24.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.64.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.4.0",
    "n8n-workflow": "^2.16.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
